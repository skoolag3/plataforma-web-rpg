generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                        String    @db.VarChar(100)
  email                       String    @unique @db.VarChar(255)
  senha_hash                  String    @db.VarChar(255)
  email_verificado            Boolean   @default(false)
  token_verificacao_email     String?   @unique @db.VarChar(255)
  token_verificacao_expira_em DateTime? @db.Timestamptz(0)
  bloqueado                   Boolean?  @default(false)
  tentativas_login            Int?      @default(0)
  is_admin                    Boolean?  @default(false)
  nivel                       Int?      @default(1)
  pontos_experiencia          Int?      @default(0)
  saldo_rubys_cache           Int?      @default(0)
  ativo                       Boolean?  @default(true)
  criado_em                   DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em               DateTime? @default(now()) @db.Timestamptz(0)
  excluido_em                 DateTime? @db.Timestamptz(0)

  transacoes           LogTransacao[]
  ledgerRubys          LedgerRuby[]
  gachaLogs            LogGacha[]
  bannerColetas        UsuarioBannerColeta[]
  inventarios          Inventario[]
  decks                Deck[]
  partidas             LogPartida[]          @relation("PartidasUsuario")
  partidasComoOponente LogPartida[]          @relation("PartidasOponente")

  @@map("usuario")
}

model PacoteRuby {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_stripe        String    @unique @db.VarChar(255)
  nome             String    @db.VarChar(100)
  quantidade_rubys Int
  preco_brl        Decimal   @db.Decimal(10, 2)
  ativo            Boolean?  @default(true)
  criado_em        DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em    DateTime? @default(now()) @db.Timestamptz(0)

  transacoes LogTransacao[]

  @@map("pacote_ruby")
}

model LogTransacao {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario       String?   @db.Uuid
  id_pacote        String?   @db.Uuid
  valor_brl        Decimal   @db.Decimal(10, 2)
  status_pagamento String    @db.VarChar(50)
  id_stripe_intent String?   @db.VarChar(255)
  timestamp_compra DateTime? @default(now()) @db.Timestamptz(0)

  usuario Usuario?    @relation(fields: [id_usuario], references: [id])
  pacote  PacoteRuby? @relation(fields: [id_pacote], references: [id])

  @@index([id_usuario], map: "idx_log_transacao_usuario")
  @@map("log_transacao")
}

model LedgerRuby {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario    String    @db.Uuid
  quantidade    Int
  motivo        String    @db.VarChar(50)
  id_referencia String?   @db.Uuid
  descricao     String?
  criado_em     DateTime? @default(now()) @db.Timestamptz(0)

  usuario Usuario @relation(fields: [id_usuario], references: [id], onDelete: Cascade)

  @@index([id_usuario], map: "idx_ledger_ruby_usuario")
  @@map("ledger_ruby")
}

model Carta {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String    @db.VarChar(150)
  elemento      String    @db.VarChar(20)
  raridade      String    @db.VarChar(50)
  hp_base       Int       @default(0)
  dano_base     Int       @default(0)
  defesa_base   Int       @default(0)
  passiva       Json?
  foto          String?   @db.VarChar(255)
  ativo         Boolean?  @default(true)
  criado_em     DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em DateTime? @default(now()) @db.Timestamptz(0)
  excluido_em   DateTime? @db.Timestamptz(0)

  banners     BannerCarta[]
  gachaLogs   LogGacha[]
  inventarios Inventario[]
  deckCartas  DeckCarta[]

  @@map("carta")
}

model Banner {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome          String    @db.VarChar(150)
  custo_giro    Int       @default(100)
  ativo         Boolean?  @default(true)
  criado_em     DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em DateTime? @default(now()) @db.Timestamptz(0)

  cartas         BannerCarta[]
  gachaLogs      LogGacha[]
  usuarioColetas UsuarioBannerColeta[]

  @@map("banner")
}

model BannerCarta {
  id_banner String  @db.Uuid
  id_carta  String  @db.Uuid
  taxa_drop Decimal @db.Decimal(5, 2)

  banner Banner @relation(fields: [id_banner], references: [id], onDelete: Cascade)
  carta  Carta  @relation(fields: [id_carta], references: [id], onDelete: Cascade)

  @@id([id_banner, id_carta])
  @@index([id_banner], map: "idx_banner_carta_banner")
  @@map("banner_carta")
}

model LogGacha {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario      String    @db.Uuid
  id_banner       String    @db.Uuid
  id_carta_obtida String    @db.Uuid
  rubys_gastos    Int
  pity_contador   Int       @default(0)
  timestamp_pull  DateTime? @default(now()) @db.Timestamptz(0)

  usuario     Usuario @relation(fields: [id_usuario], references: [id])
  banner      Banner  @relation(fields: [id_banner], references: [id])
  cartaObtida Carta   @relation(fields: [id_carta_obtida], references: [id])

  @@index([id_usuario], map: "idx_log_gacha_usuario")
  @@index([id_banner], map: "idx_log_gacha_banner")
  @@index([timestamp_pull(sort: Desc)], map: "idx_log_gacha_timestamp")
  @@map("log_gacha")
}

model UsuarioBannerColeta {
  id_usuario    String    @db.Uuid
  id_banner     String    @db.Uuid
  ultima_coleta DateTime? @db.Timestamptz(0)

  usuario Usuario @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  banner  Banner  @relation(fields: [id_banner], references: [id], onDelete: Cascade)

  @@id([id_usuario, id_banner])
  @@map("usuario_banner_coleta")
}

model Inventario {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario    String?   @db.Uuid
  id_carta      String?   @db.Uuid
  quantidade    Int?      @default(1)
  criado_em     DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em DateTime? @default(now()) @db.Timestamptz(0)

  usuario Usuario? @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  carta   Carta?   @relation(fields: [id_carta], references: [id])

  @@unique([id_usuario, id_carta], map: "uq_inventario_usuario_carta")
  @@index([id_usuario], map: "idx_inventario_usuario")
  @@map("inventario")
}

model Deck {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario    String?   @db.Uuid
  nome          String    @default("Meu Deck") @db.VarChar(100)
  ativo         Boolean?  @default(false)
  criado_em     DateTime? @default(now()) @db.Timestamptz(0)
  atualizado_em DateTime? @default(now()) @db.Timestamptz(0)
  excluido_em   DateTime? @db.Timestamptz(0)

  usuario  Usuario?     @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cartas   DeckCarta[]
  partidas LogPartida[]

  @@map("deck")
}

model DeckCarta {
  id_deck      String    @db.Uuid
  id_carta     String    @db.Uuid
  posicao_slot Int
  criado_em    DateTime? @default(now()) @db.Timestamptz(0)

  deck  Deck  @relation(fields: [id_deck], references: [id], onDelete: Cascade)
  carta Carta @relation(fields: [id_carta], references: [id], onDelete: Cascade)

  @@id([id_deck, id_carta])
  @@unique([id_deck, posicao_slot], map: "uq_deck_posicao")
  @@map("deck_carta")
}

model LogPartida {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario          String?   @db.Uuid
  id_usuario_oponente String?   @db.Uuid
  id_deck_usado       String?   @db.Uuid
  resultado           String    @db.VarChar(20)
  turnos_jogados      Int       @default(0)
  variacao_pontos     Int?      @default(0)
  timestamp_inicio    DateTime? @default(now()) @db.Timestamptz(0)
  timestamp_fim       DateTime? @db.Timestamptz(0)

  usuario  Usuario? @relation("PartidasUsuario", fields: [id_usuario], references: [id])
  oponente Usuario? @relation("PartidasOponente", fields: [id_usuario_oponente], references: [id])
  deck     Deck?    @relation(fields: [id_deck_usado], references: [id])

  @@index([id_usuario], map: "idx_log_partida_usuario")
  @@index([id_usuario_oponente], map: "idx_log_partida_oponente")
  @@index([timestamp_inicio(sort: Desc)], map: "idx_log_partida_timestamp")
  @@map("log_partida")
}
